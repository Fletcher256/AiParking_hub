#!/bin/sh

# Boot-time STM32 USB-UART link init.
# Starts a background initializer only. It does not start control software.

LOG="${LOG:-/tmp/parking_stm32_uart_boot.log}"
SCRIPT="${SCRIPT:-/opt/parking/stm32_uart/stm32_uart_boot_init.sh}"

{
    echo "S98STM32UART_BEGIN $(date +%s 2>/dev/null || echo 0)"
    if [ -x "$SCRIPT" ]; then
        "$SCRIPT" &
        echo "S98STM32UART_STARTED $!"
    else
        echo "S98STM32UART_SCRIPT_MISSING $SCRIPT"
    fi
    echo "S98STM32UART_END $(date +%s 2>/dev/null || echo 0)"
} >> "$LOG" 2>&1

exit 0
